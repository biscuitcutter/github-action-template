{
  "name": "{{ cookiecutter.action_slug }}",
  "version": "1.0.0",
  "description": "{{ cookiecutter.action_description }}",
  "main": "dist/index.js",
  "scripts": {
    "build": "ncc build src/main.ts -o dist --source-map --license licenses.txt",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "typecheck": "tsc --noEmit",
    "all": "npm run lint && npm run typecheck && npm run test && npm run build"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/{{ cookiecutter.github_username }}/{{ cookiecutter.action_slug }}.git"
  },
  "keywords": [
    "github-action",
    "actions"
  ],
  "author": "{{ cookiecutter.author_name }} <{{ cookiecutter.author_email }}>",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.10.1",
    "@actions/github": "^6.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@vercel/ncc": "^0.38.1",
    "eslint": "^9.0.0",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  }
}
